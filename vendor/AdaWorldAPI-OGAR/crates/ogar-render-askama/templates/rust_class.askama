    /// {{ f.origin }} `{{ f.snake_name }}`.
    pub {{ f.snake_name }}: {{ f.rust_type }},
{%- endfor %}
}

impl {{ name }} {
{%- if class_id_hex.len() > 0 %}
    /// Canonical codebook id for this class.
    pub const CLASS_ID: u16 = {{ class_id_hex }};
{%- endif %}

    /// Struct-of-methods constructor over the ClassView × FieldMask field set.
    pub fn new({{ ctor_params }}) -> Self {
