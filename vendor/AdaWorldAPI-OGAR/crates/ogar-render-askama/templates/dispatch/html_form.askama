{# Form view — create/edit one canonical record. Substrate-agnostic;    #}
{# driven by `fields` (per-attribute pre-rendered <input>s).            #}
{# Pre-rendered field bodies are |safe (each sub-template escapes its   #}
{# own variables); everything else is HTML-escaped by the spine.         #}
<form class="ogar-form" data-class-id="{{ class_id_hex }}" data-concept="{{ canonical_concept }}" method="{{ method }}" action="{{ action }}">
  {%- if !csrf_token.is_empty() %}
  <input type="hidden" name="authenticity_token" value="{{ csrf_token }}">
  {%- endif %}
  {%- if !record_id_html.is_empty() %}
  {{ record_id_html|safe }}
  {%- endif %}
  <fieldset class="form-fields">
    {%- if !legend.is_empty() %}
    <legend>{{ legend }}</legend>
    {%- endif %}
    {%- for field in fields %}
      {%- if field.hidden %}
      {{ field.body_html|safe }}
      {%- else %}
    <div class="form-field form-field-{{ field.name }}{% if !field.css_classes.is_empty() %} {{ field.css_classes }}{% endif %}">
      <label for="field-{{ field.name }}">{{ field.label }}{% if field.required %} <span class="required">*</span>{% endif %}</label>
      {{ field.body_html|safe }}
      {%- if !field.hint.is_empty() %}
      <small class="hint">{{ field.hint }}</small>
      {%- endif %}
    </div>
      {%- endif %}
    {%- endfor %}
  </fieldset>
  <div class="form-actions">
    <button type="submit" class="btn-primary">{{ submit_label }}</button>
    {%- if !cancel_href.is_empty() %}
    <a href="{{ cancel_href }}" class="btn-cancel">{{ cancel_label }}</a>
    {%- endif %}
  </div>
</form>
