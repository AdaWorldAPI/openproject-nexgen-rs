{# Spine list template — Redmine `_list.html.erb` shape on our substrate. #}
{# Substrate-agnostic: nothing here knows it's rendering issues vs projects #}
{# vs users. Driven by `inline_columns`, `block_columns`, `rows`.            #}
<div class="ogar-list" data-class-id="{{ class_id_hex }}" data-concept="{{ canonical_concept }}">
<h2>{{ title }}</h2>
<div class="autoscroll">
<table class="list">
  <thead>
    <tr>
      <th class="checkbox"><input type="checkbox" class="toggle-selection"></th>
      {%- for col in inline_columns %}
      <th class="col-{{ col.name }}{% if col.sortable %} sortable{% endif %}{% if col.frozen %} frozen{% endif %}">
        {%- if col.sortable -%}
        <a href="?sort={{ col.name }}:{{ col.default_order_str }}" class="sort-link">{{ col.caption }}</a>
        {%- else -%}
        {{ col.caption }}
        {%- endif -%}
      </th>
      {%- endfor %}
      <th class="buttons"></th>
    </tr>
  </thead>
  <tbody>
    {%- for row in rows %}
      {%- if !row.group_header_label.is_empty() %}
    <tr class="group open">
      <td colspan="{{ inline_columns.len() + 2 }}">
        <span class="name">{{ row.group_header_label }}</span>
        {%- if row.group_header_count > 0 %} <span class="badge">{{ row.group_header_count }}</span>{% endif -%}
      </td>
    </tr>
      {%- endif %}
    <tr id="record-{{ row.record_id }}" class="{{ row.css_classes }}">
      <td class="checkbox"><input type="checkbox" name="ids[]" value="{{ row.record_id }}"></td>
      {%- for cell in row.inline_cells %}
      <td class="col-{{ cell.name }} {{ cell.css_classes }}">{{ cell.body_html|safe }}</td>
      {%- endfor %}
      <td class="buttons"></td>
    </tr>
      {%- for cell in row.block_cells %}
        {%- if !cell.body_html.is_empty() %}
    <tr class="{{ row.css_classes }} block-row">
      <td colspan="{{ inline_columns.len() + 2 }}" class="block_column col-{{ cell.name }} {{ cell.css_classes }}">
        {{ cell.body_html|safe }}
      </td>
    </tr>
        {%- endif %}
      {%- endfor %}
    {%- endfor %}
    {%- if rows.is_empty() %}
    <tr><td colspan="{{ inline_columns.len() + 2 }}" class="nodata muted">No data.</td></tr>
    {%- endif %}
  </tbody>
</table>
</div>
</div>
